# =============================================
# 初中地生会考练习系统 - 环境变量配置
# =============================================
# 详细部署教程请查看: DEPLOYMENT.md
# =============================================

# Supabase 数据库配置（必填）
# 在 Supabase 项目设置 -> API 中获取
# --------------------------------------------
# 项目 URL
COZE_SUPABASE_URL=https://your-project-id.supabase.co

# Anon Key（公开密钥，可暴露在前端）
COZE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNjAwMDAwMDAwLCJleHAiOjE5MDAwMDAwMDB9.xxxxx

# 备用变量名（与上面二选一，效果相同）
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...

# =============================================
# 以下为可选配置
# =============================================

# 管理员密码（可选，默认 admin123）
# ⚠️ 生产环境强烈建议修改此密码
# ADMIN_PASSWORD=your-secure-password

# VIP 价格（可选，默认 10 元）
# VIP_PRICE=10

# VIP 有效期小时数（可选，默认 24 小时）
# VIP_DURATION_HOURS=24

# ZhuPay 支付配置（可选，用于真实支付）
# ZHUPAY_UID=your-uid
# ZHUPAY_KEY=your-key
